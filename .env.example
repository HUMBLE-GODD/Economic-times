# Environment Configuration Example
# Copy this file to .env and fill in your keys. NEVER commit actual secret API keys to public version control.

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Industrial Safety Platform Settings
SAFETY_DB_PATH=backend/safety_platform.db
APP_SECRET=dev-secret-change-before-production
ACCESS_TTL_SECONDS=3600
PORT=8000
